<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:navigationIcon="@android:drawable/ic_menu_revert"
        app:navigationIconTint="@color/white"
        app:title="Chi tiết đơn hàng"
        app:titleTextColor="@color/white"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card 1: Trạng thái & Stepper -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvOrderDetailStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trạng thái: Đang chuẩn bị"
                        android:textColor="@color/on_surface"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- Tracker Stepper (Horizontal) -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="32dp">

                        <View
                            android:id="@+id/stepLine"
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:background="@color/surface_variant"
                            app:layout_constraintTop_toTopOf="@id/indicator1"
                            app:layout_constraintBottom_toBottomOf="@id/indicator1" />

                        <!-- Indicator 1: Đã đặt -->
                        <View
                            android:id="@+id/indicator1"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:background="@drawable/bg_step_inactive"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/lblStep1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Đã đặt"
                            android:textSize="10sp"
                            app:layout_constraintStart_toStartOf="@id/indicator1"
                            app:layout_constraintEnd_toEndOf="@id/indicator1"
                            app:layout_constraintTop_toBottomOf="@id/indicator1" />

                        <!-- Indicator 2: Đang chuẩn bị -->
                        <View
                            android:id="@+id/indicator2"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:background="@drawable/bg_step_inactive"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintEnd_toStartOf="@id/indicator3"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/lblStep2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Chuẩn bị"
                            android:textSize="10sp"
                            app:layout_constraintStart_toStartOf="@id/indicator2"
                            app:layout_constraintEnd_toEndOf="@id/indicator2"
                            app:layout_constraintTop_toBottomOf="@id/indicator2" />

                        <!-- Indicator 3: Đang giao -->
                        <View
                            android:id="@+id/indicator3"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:background="@drawable/bg_step_inactive"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/indicator2"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/lblStep3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Đang giao"
                            android:textSize="10sp"
                            app:layout_constraintStart_toStartOf="@id/indicator3"
                            app:layout_constraintEnd_toEndOf="@id/indicator3"
                            app:layout_constraintTop_toBottomOf="@id/indicator3" />

                        <!-- Indicator 4: Hoàn thành -->
                        <View
                            android:id="@+id/indicator4"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:background="@drawable/bg_step_inactive"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/lblStep4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Đã nhận"
                            android:textSize="10sp"
                            app:layout_constraintStart_toStartOf="@id/indicator4"
                            app:layout_constraintEnd_toEndOf="@id/indicator4"
                            app:layout_constraintTop_toBottomOf="@id/indicator4" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 2: Thông tin tài xế (nếu có) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvShipperInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin tài xế"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="@color/grey_text" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <androidx.cardview.widget.CardView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            app:cardCornerRadius="24dp">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@android:drawable/ic_menu_myplaces"
                                android:scaleType="centerCrop"
                                app:tint="@color/primary" />
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvShipperName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Tài xế Nguyễn Văn A"
                                android:textStyle="bold"
                                android:textSize="15sp" />

                            <TextView
                                android:id="@+id/tvShipperVehicle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lotte Express • Xe máy"
                                android:textSize="13sp"
                                android:textColor="@color/grey_text" />
                        </LinearLayout>

                        <ImageButton
                            android:id="@+id/btnCallShipper"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_icon_button"
                            android:src="@android:drawable/ic_menu_call"
                            app:tint="@color/on_surface" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card 3: Chi tiết đơn hàng -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvDetailOrderId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mã đơn hàng: #LM982301"
                        android:textStyle="bold"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvDetailOrderDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Ngày đặt: 10/06/2026 14:30"
                        android:textColor="@color/grey_text"
                        android:textSize="13sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#EEEEEE" />

                    <!-- List of items (Programmatically populated) -->
                    <LinearLayout
                        android:id="@+id/llOrderItemsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#EEEEEE" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Phí giao hàng"
                            android:textColor="@color/grey_text" />
                        <TextView
                            android:id="@+id/tvDetailShippingFee"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="15,000 đ" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Phương thức thanh toán"
                            android:textColor="@color/grey_text" />
                        <TextView
                            android:id="@+id/tvDetailPaymentMethod"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="COD" />
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tổng thanh toán"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface" />
                        <TextView
                            android:id="@+id/tvDetailOrderTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="165,000 đ"
                            android:textColor="@color/primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Actions buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTrackShipper"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:text="XEM TÌNH HÌNH SHIPPER"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:visibility="gone"
                app:cornerRadius="12dp"
                app:backgroundTint="@color/primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRateOrder"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="ĐÁNH GIÁ ĐƠN HÀNG"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:visibility="gone"
                app:cornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/primary"
                app:backgroundTint="@color/white" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
