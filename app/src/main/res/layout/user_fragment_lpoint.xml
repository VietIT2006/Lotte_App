<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF8F7">

    <View
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="#E1251B"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="-100dp"
        android:layout_marginHorizontal="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="L.POINT CỦA TÔI"
                android:textSize="14sp"
                android:textColor="#5D3F3B"/>

            <TextView
                android:id="@+id/tvLPointBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12,450 P"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#E1251B"
                android:layout_marginTop="8dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E7BDB7"
                android:layout_marginVertical="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sắp hết hạn"
                        android:textSize="12sp"
                        android:textColor="#5D3F3B"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 P"
                        android:textStyle="bold"
                        android:textColor="#291714"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tháng này tích lũy"
                        android:textSize="12sp"
                        android:textColor="#5D3F3B"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+1,200 P"
                        android:textStyle="bold"
                        android:textColor="#005DA3"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tiện ích"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_margin="16dp"
        android:textColor="#291714"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:layout_marginHorizontal="16dp">
        
        <!-- Mock icons -->
        <LinearLayout android:orientation="vertical" android:gravity="center" android:layout_columnWeight="1" android:padding="8dp">
            <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/ic_menu_send" app:tint="#E1251B"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Chuyển điểm" android:textSize="10sp" android:layout_marginTop="4dp" android:gravity="center"/>
        </LinearLayout>

        <LinearLayout android:orientation="vertical" android:gravity="center" android:layout_columnWeight="1" android:padding="8dp">
            <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/ic_menu_add" app:tint="#E1251B"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Nạp điểm" android:textSize="10sp" android:layout_marginTop="4dp" android:gravity="center"/>
        </LinearLayout>

        <LinearLayout android:orientation="vertical" android:gravity="center" android:layout_columnWeight="1" android:padding="8dp">
            <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/ic_menu_agenda" app:tint="#E1251B"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lịch sử" android:textSize="10sp" android:layout_marginTop="4dp" android:gravity="center"/>
        </LinearLayout>

        <LinearLayout android:orientation="vertical" android:gravity="center" android:layout_columnWeight="1" android:padding="8dp">
            <ImageView android:layout_width="40dp" android:layout_height="40dp" android:src="@android:drawable/ic_menu_view" app:tint="#E1251B"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thẻ của tôi" android:textSize="10sp" android:layout_marginTop="4dp" android:gravity="center"/>
        </LinearLayout>
    </GridLayout>

</LinearLayout>
