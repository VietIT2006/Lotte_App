<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Transaction Icon Indicator -->
        <ImageView
            android:id="@+id/ivTxIcon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_input_add"
            app:tint="#388E3C"
            android:background="#E8F5E9"
            android:padding="6dp"
            android:layout_marginEnd="12dp"/>

        <!-- Text Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTxTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cộng tiền giao đơn"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#303333"/>

            <TextView
                android:id="@+id/tvTxDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="11/06/2026 10:19"
                android:textSize="11sp"
                android:textColor="@color/grey_text"/>
        </LinearLayout>

        <!-- Amount -->
        <TextView
            android:id="@+id/tvTxAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+20.000đ"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#388E3C"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
