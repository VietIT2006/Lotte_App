<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="180dp"
    android:background="@color/primary"
    android:padding="16dp"
    android:gravity="bottom"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/imgHeaderDriverAvatar"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@mipmap/ic_launcher_round"
        android:background="@drawable/circle_background"
        android:padding="2dp"
        android:contentDescription="Driver Avatar" />

    <TextView
        android:id="@+id/tvHeaderDriverName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Tài xế Lotte"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvHeaderDriverStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="ĐỐI TÁC CHUYÊN NGHIỆP"
        android:textColor="#FFCDD2"
        android:textSize="12sp"
        android:textStyle="bold" />

</LinearLayout>
