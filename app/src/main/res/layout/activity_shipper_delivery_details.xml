<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FBF9F8">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/btnCompleteOrderLayout"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Google Map View -->
            <WebView
                android:id="@+id/mapWebView"
                android:layout_width="match_parent"
                android:layout_height="250dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginTop="-20dp"
                android:background="@drawable/bottom_sheet_bg"
                android:elevation="4dp">

                <!-- Order Info -->
                <TextView
                    android:id="@+id/tvOrderId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Order #ZLD-8824-01"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#303333"/>

                <!-- Destination Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DESTINATION"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#5D5F60"/>
                        <TextView
                            android:id="@+id/tvDestination"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Lotte Tower Residence, Apt 402"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#303333"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Customer Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">
                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@mipmap/ic_launcher_round"/>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">
                            <TextView
                                android:id="@+id/tvCustomerName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ji-won Kim"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#303333"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Regular Member"
                                android:textSize="12sp"
                                android:textColor="#5D5F60"/>
                        </LinearLayout>
                        <Button
                            android:id="@+id/btnCall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Call"
                            android:backgroundTint="#F5F3F3"
                            android:textColor="#C00004"
                            app:icon="@android:drawable/ic_menu_call"
                            app:iconTint="#C00004"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Payment Summary -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PAYMENT SUMMARY"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#5D5F60"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"/>
                    
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="COD Total"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#303333"/>
                    <TextView
                        android:id="@+id/tvCodTotal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="146,000đ"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#C00004"/>
                </LinearLayout>

                <!-- Checklist Placeholder (You'd use a RecyclerView here for real items) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PICK CHECKLIST"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#5D5F60"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="8dp"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Button -->
    <LinearLayout
        android:id="@+id/btnCompleteOrderLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:padding="16dp"
        android:background="@color/white"
        android:elevation="8dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <Button
                android:id="@+id/btnStartDelivery"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="BẮT ĐẦU GIAO"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="#008800"
                app:cornerRadius="8dp"/>

            <Button
                android:id="@+id/btnCompleteOrder"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="HOÀN TẤT ĐƠN"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="#C00004"
                app:cornerRadius="8dp"/>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
