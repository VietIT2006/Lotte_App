<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TỔNG QUAN HỆ THỐNG"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#9E9E9E"
                android:layout_marginBottom="12dp"
                android:letterSpacing="0.1"/>

            <!-- 4 KPI Overview Cards (2x2 Grid using LinearLayouts) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="12dp">

                <!-- KPI Card 1: Revenue -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:drawable/dialog_holo_light_frame"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/tvKpi1Label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Doanh thu"
                            android:textColor="#757575"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tvKpi1Value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:text="145.8M đ"
                            android:textColor="#E53935"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- KPI Card 2: Orders -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:drawable/dialog_holo_light_frame"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/tvKpi2Label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tổng đơn hàng"
                            android:textColor="#757575"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tvKpi2Value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:text="1,248"
                            android:textColor="#1E88E5"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="20dp">

                <!-- KPI Card 3: Products -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:drawable/dialog_holo_light_frame"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/tvKpi3Label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kho hàng"
                            android:textColor="#757575"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tvKpi3Value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:text="382 mã"
                            android:textColor="#43A047"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <!-- KPI Card 4: Customers -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp">
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:drawable/dialog_holo_light_frame"
                        android:padding="16dp">
                        <TextView
                            android:id="@+id/tvKpi4Label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thành viên"
                            android:textColor="#757575"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tvKpi4Value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:text="854"
                            android:textColor="#FFB300"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Revenue Chart Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/white">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BIỂU ĐỒ DOANH THU TUẦN NÀY"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#9E9E9E"
                        android:letterSpacing="0.05"/>
                    <TextView
                        android:id="@+id/tvChartTotalRevenue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="675,000 đ"
                        android:textColor="#E53935"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal"
                        android:gravity="bottom">
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                            <View android:layout_width="12dp" android:layout_height="35dp" android:background="#E53935" android:backgroundTint="#FF8A80"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T2" android:textSize="8sp" android:textColor="#9E9E9E" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                            <View android:layout_width="12dp" android:layout_height="50dp" android:background="#E53935" android:backgroundTint="#FF8A80"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T3" android:textSize="8sp" android:textColor="#9E9E9E" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                            <View android:layout_width="12dp" android:layout_height="20dp" android:background="#E53935" android:backgroundTint="#FF8A80"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T4" android:textSize="8sp" android:textColor="#9E9E9E" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                            <View android:layout_width="12dp" android:layout_height="65dp" android:background="#E53935" android:backgroundTint="#FF5252"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T5" android:textSize="8sp" android:textColor="#9E9E9E" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                            <View android:layout_width="12dp" android:layout_height="40dp" android:background="#E53935" android:backgroundTint="#FF8A80"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T6" android:textSize="8sp" android:textColor="#9E9E9E" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                            <View android:layout_width="12dp" android:layout_height="55dp" android:background="#E53935" android:backgroundTint="#FF8A80"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="T7" android:textSize="8sp" android:textColor="#9E9E9E" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:orientation="vertical" android:gravity="bottom|center_horizontal">
                            <View android:layout_width="12dp" android:layout_height="75dp" android:background="#E53935"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CN" android:textSize="8sp" android:textColor="#9E9E9E" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SECTION: PENDING CONFIRMATIONS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ĐƠN HÀNG MỚI CHỜ DUYỆT"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#9E9E9E"
                android:layout_marginBottom="12dp"
                android:letterSpacing="0.1"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPendingOrders"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="24dp" />

            <!-- SECTION: SUPER ADMIN SPECIAL APPROVALS -->
            <LinearLayout
                android:id="@+id/llSuperAdminApprovals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Products Pending Approval -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SẢN PHẨM MỚI CHỜ DUYỆT (SUPER ADMIN)"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#9E9E9E"
                    android:layout_marginBottom="12dp"
                    android:letterSpacing="0.1"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPendingProducts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginBottom="24dp" />

                <!-- Categories Pending Approval -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DANH MỤC MỚI CHỜ DUYỆT (SUPER ADMIN)"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#9E9E9E"
                    android:layout_marginBottom="12dp"
                    android:letterSpacing="0.1"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPendingCategories"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginBottom="12dp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
